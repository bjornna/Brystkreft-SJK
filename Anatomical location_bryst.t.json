        "at0065.1" : {
          "@type" : "ARCHETYPE_TERM",
          "code" : "at0065",
          "text" : "Spesifikt sted",
          "description" : "Ytterligere detaljer gitt ved hjelp av en spesifikk region eller et punkt på eller i det spesifiserte kroppsstedet.",
          "comment" : "Designkommentar:\nListe over spesifikk kroppssted for hvor man har tatt bildeundersøkelsen. \n\nI SJK har vi brukt denne i stedet for den overordnede da vi trenger å ha denne repiterende. "
        }
